
<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/playlist/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Nova Playlist</h2>
            
            <form method="post" >
                <div class="form-group">
                    <label for="nome">Nome</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                </div>
                <div class="form-group">
                    <label for="musica1">Música 1</label>
                    <input 
                        type="text" 
                        id="musica1" 
                        name="musica1" 
                        
                    >
                </div>
                <div class="form-group">
                    <label for="musica2">Música 2</label>
                    <input 
                        type="text" 
                        id="musica2" 
                        name="musica2" 
                        
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/playlist/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>